{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (J-Link)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "jlink",
      "device": "STM32WLE5JC",
      "interface": "swd",
      "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
      "gdbPath": "/home/strooom/projects/zephyr/sdks/zephyr-sdk-0.17.4/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
      "svdFile": "${workspaceFolder}/svd/stm32wle5.svd",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    }
  ]
}
